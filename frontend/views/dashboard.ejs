<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- TailwindCSS for cyberpunk styling -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/global.css">
</head>

<body class="bg-black text-cyan-300 font-mono">
  <!-- Shared nav -->
  <%- include("components/nav") %>

  <!-- Header -->
  <header class="p-4 bg-gray-900 border-b border-cyan-400 flex justify-between items-center">
    <h1 class="text-2xl neon-text">📊 Admin Dashboard</h1>
    <a href="/logout" id="logoutBtn" class="px-4 py-2 bg-red-600 hover:bg-red-700 rounded">Logout</a>
  </header>

  <!-- Analytics Section -->
  <section class="p-6 grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Teachers by Subject -->
    <div class="bg-gray-900 p-4 rounded shadow-neon">
      <h2 class="text-xl mb-2">Teachers by Subject</h2>
      <canvas id="teachersChart"></canvas>
    </div>

    <!-- Attendance Summary -->
    <div class="bg-gray-900 p-4 rounded shadow-neon">
      <h2 class="text-xl mb-2">Attendance Summary</h2>
      <canvas id="attendanceChart"></canvas>
    </div>

    <!-- Grades by Class -->
    <div class="bg-gray-900 p-4 rounded shadow-neon">
      <h2 class="text-xl mb-2">Grades by Class</h2>
      <canvas id="gradesChart"></canvas>
    </div>
  </section>

  <!-- Chart.js + Dashboard Script -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script type="module" src="/assets/js/dashboard.js"></script>

  <!-- Shared footer -->
  <%- include("components/footer") %>
</body>
</html>
