<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/global.css">
</head>
<body class="bg-black text-cyan-300 font-mono">
  <%- include("components/nav") %>

  <section class="flex justify-center items-center h-screen">
    <div class="bg-gray-900 p-8 rounded shadow-neon w-96">
      <h1 class="text-2xl mb-6 neon-text">📝 Register</h1>
      <form id="registerForm" class="space-y-4">
        <input type="text" id="username" placeholder="Username" class="w-full p-2 rounded bg-gray-800 text-cyan-300">
        <input type="password" id="password" placeholder="Password" class="w-full p-2 rounded bg-gray-800 text-cyan-300">
        <select id="role" class="w-full p-2 rounded bg-gray-800 text-cyan-300">
          <option value="student">Student</option>
          <option value="teacher">Teacher</option>
          <option value="admin">Admin</option>
        </select>
        <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 p-2 rounded">Register</button>
      </form>
      <p class="mt-4 text-sm">Already have an account? <a href="/login" class="text-cyan-400">Login here</a></p>
    </div>
  </section>

  <script type="module" src="/assets/js/register.js"></script>
  <%- include("components/footer") %>
</body>
</html>
