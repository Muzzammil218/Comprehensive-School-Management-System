<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/global.css">
</head>
<body class="bg-black text-cyan-300 font-mono">
  <%- include("components/nav") %>

  <section class="flex justify-center items-center h-screen">
    <div class="bg-gray-900 p-8 rounded shadow-neon w-96">
      <h1 class="text-2xl mb-6 neon-text">🔐 Login</h1>
      <form id="loginForm" class="space-y-4">
        <input type="text" id="username" placeholder="Username" class="w-full p-2 rounded bg-gray-800 text-cyan-300">
        <input type="password" id="password" placeholder="Password" class="w-full p-2 rounded bg-gray-800 text-cyan-300">
        <button type="submit" class="w-full bg-cyan-600 hover:bg-cyan-700 p-2 rounded">Login</button>
      </form>
      <p class="mt-4 text-sm">No account? <a href="/register" class="text-purple-400">Register here</a></p>
    </div>
  </section>

  <script type="module" src="/assets/js/login.js"></script>
  <%- include("components/footer") %>
</body>
</html>
