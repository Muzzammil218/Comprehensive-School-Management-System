<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Manage Teachers</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- TailwindCSS for cyberpunk styling -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/global.css">
</head>

<body class="bg-black text-cyan-300 font-mono">
  <!-- Shared nav -->
  <%- include("components/nav") %>

    <!-- Header -->
    <header class="p-4 bg-gray-900 border-b border-cyan-400 flex justify-between items-center">
      <h1 class="text-2xl neon-text">👩‍🏫 Teacher Management</h1>
      <a href="/dashboard" class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 rounded">Back to Dashboard</a>
    </header>

    <!-- Teacher Form -->
    <section class="p-6">
      <h2 class="text-xl mb-4">Add New Teacher</h2>
      <form id="teacherForm" class="space-y-4 bg-gray-800 p-4 rounded shadow-neon">
        <input id="teacherFirstName" type="text" placeholder="First Name"
          class="w-full p-2 rounded bg-black border border-cyan-400 text-cyan-300" required>
        <input id="teacherLastName" type="text" placeholder="Last Name"
          class="w-full p-2 rounded bg-black border border-cyan-400 text-cyan-300" required>
        <input id="teacherEmail" type="email" placeholder="Email"
          class="w-full p-2 rounded bg-black border border-cyan-400 text-cyan-300" required>
        <input id="teacherPhone" type="text" placeholder="Phone Number"
          class="w-full p-2 rounded bg-black border border-cyan-400 text-cyan-300" required>
        <input id="teacherHireDate" type="date" placeholder="Hire Date"
          class="w-full p-2 rounded bg-black border border-cyan-400 text-cyan-300" required>
        <input id="teacherSubject" type="text" placeholder="Subject"
          class="w-full p-2 rounded bg-black border border-cyan-400 text-cyan-300" required>
        <button type="submit" class="px-4 py-2 bg-green-600 hover:bg-green-700 rounded">Add Teacher</button>
      </form>

    </section>

    <!-- Teacher Table -->
    <section class="p-6">
      <h2 class="text-xl mb-4">Teacher Records</h2>
      <table class="w-full border border-cyan-400 text-cyan-300">
        <thead class="bg-gray-900">
          <tr>
            <th class="p-2 border border-cyan-400">ID</th>
            <th class="p-2 border border-cyan-400">Name</th>
            <th class="p-2 border border-cyan-400">Subject</th>
            <th class="p-2 border border-cyan-400">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-gray-800">
          <% teachers.forEach(teacher=> { %>
            <tr>
              <td class="p-2 border border-cyan-400">
                <%= teacher.id %>
              </td>
              <td class="p-2 border border-cyan-400">
                <%= teacher.name %>
              </td>
              <td class="p-2 border border-cyan-400">
                <%= teacher.subject %>
              </td>
              <td class="p-2 border border-cyan-400">
                <button class="px-2 py-1 bg-yellow-600 hover:bg-yellow-700 rounded">Edit</button>
                <button class="px-2 py-1 bg-red-600 hover:bg-red-700 rounded">Delete</button>
              </td>
            </tr>
            <% }) %>
        </tbody>
      </table>
    </section>

    <!-- Scripts -->
    <script type="module" src="/assets/js/teachers.js"></script>

    <!-- Shared footer -->
    <%- include("components/footer") %>
</body>

</html>